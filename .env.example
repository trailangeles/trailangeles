# Environment variables for the public edit-request functions.
# Copy to `.env` for local `netlify dev`, and set the same values in the
# Netlify UI (Site configuration → Environment variables) for deploys.

# --- GitHub App (opens PRs on behalf of anonymous contributors) ---
GH_APP_ID=
GH_APP_INSTALLATION_ID=
# Paste the PEM contents. Newlines may be literal "\n" — the code handles both.
GH_APP_PRIVATE_KEY=
# Optional overrides (defaults shown):
# GH_REPO=trailangeles/trailangeles
# GH_BRANCH=main

# --- Magic-link signing (any long random string) ---
MAGIC_LINK_SECRET=

# --- Resend (sends the confirmation email) ---
RESEND_API_KEY=
# Must be a verified sender on your Resend domain:
EMAIL_FROM=TrailAngeles <edits@trailangeles.org>
